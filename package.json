{
  "name": "nextjs-template",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "postinstall": "playwright install chromium",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ .storybook/",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "depcruise": "depcruise src/",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:text": "textlint \"src/**/*.tsx\"",
    "lint:text:fix": "textlint --fix \"src/**/*.tsx\"",
    "lint:actions": "mise exec -- actionlint",
    "scan:secretlint": "secretlint --secretlintignore .gitignore \"**/*\"",
    "scan:gitleaks": "mise exec -- gitleaks git --redact --no-banner",
    "lint:sh": "git ls-files --cached --others --exclude-standard '*.sh' | xargs mise exec -- shellcheck",
    "format:sh": "git ls-files --cached --others --exclude-standard '*.sh' | xargs mise exec -- shfmt -i 2 -ci -bn -sr -d",
    "format:sh:fix": "git ls-files --cached --others --exclude-standard '*.sh' | xargs mise exec -- shfmt -i 2 -ci -bn -sr -w",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "postcss@<8.5.10": ">=8.5.10",
      "smol-toml@<1.6.1": ">=1.6.1",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  },
  "dependencies": {
    "@radix-ui/themes": "^3.3.0",
    "@tanstack/react-query": "^5.101.4",
    "lucide-react": "^1.25.0",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "remeda": "^2.34.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.11",
    "@playwright/test": "^1.59.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-onboarding": "^10.5.3",
    "@storybook/addon-vitest": "^10.5.3",
    "@storybook/nextjs-vite": "^10.5.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-storybook": "^10.4.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "lefthook": "^2.1.10",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.9.6",
    "secretlint": "^13.0.4",
    "storybook": "^10.5.3",
    "textlint": "^15.7.1",
    "textlint-plugin-jsx": "^1.3.0",
    "textlint-rule-prh": "^6.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "knip": {
    "ignoreBinaries": [
      "mise"
    ],
    "ignoreDependencies": [
      "@commitlint/cli",
      "@commitlint/config-conventional",
      "@testing-library/jest-dom",
      "@testing-library/react",
      "@secretlint/secretlint-rule-preset-recommend",
      "textlint-plugin-jsx",
      "textlint-rule-prh",
      "zustand",
      "lucide-react"
    ],
    "entry": [
      "src/shared-components/**/*.{ts,tsx}",
      "src/features/**/*.{ts,tsx}",
      "src/helpers/**/*.{ts,tsx}"
    ],
    "next": {
      "entry": [
        "src/app/**/{layout,page,loading,error,not-found,template,default}.{ts,tsx}",
        "next.config.ts"
      ]
    }
  }
}
