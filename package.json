{
  "name": "nextjs-template",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "depcruise": "depcruise src/",
    "lint:md": "markdownlint-cli2",
    "lint:actions": "actionlint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-plugin-react-compiler": "1.0.0",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^10.1.0",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-unicorn": "^63.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "knip": "^6.0.1",
    "lefthook": "^2.1.4",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0",
    "storybook": "^10.3.2",
    "@storybook/nextjs-vite": "^10.3.2",
    "@chromatic-com/storybook": "^5.0.2",
    "@storybook/addon-vitest": "^10.3.2",
    "@storybook/addon-a11y": "^10.3.2",
    "@storybook/addon-docs": "^10.3.2",
    "@storybook/addon-onboarding": "^10.3.2",
    "vite": "^8.0.3",
    "playwright": "^1.58.2",
    "@vitest/browser-playwright": "^4.1.0"
  },
  "knip": {
    "ignoreBinaries": [
      "actionlint"
    ],
    "ignoreDependencies": [
      "@testing-library/jest-dom",
      "@testing-library/react",
      "postcss"
    ],
    "entry": [
      "src/shared-components/**/*.{ts,tsx}",
      "src/features/**/*.{ts,tsx}",
      "src/helpers/**/*.{ts,tsx}"
    ],
    "next": {
      "entry": [
        "src/app/**/{layout,page,loading,error,not-found,template,default}.{ts,tsx}",
        "next.config.ts"
      ]
    }
  }
}
