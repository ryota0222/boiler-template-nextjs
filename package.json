{
  "name": "nextjs-template",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "postinstall": "playwright install chromium",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "depcruise": "depcruise src/",
    "lint:md": "markdownlint-cli2",
    "lint:actions": "actionlint",
    "scan:secretlint": "secretlint --secretlintignore .gitignore \"**/*\"",
    "scan:gitleaks": "gitleaks git --redact --no-banner",
    "lint:sh": "git ls-files --cached --others --exclude-standard '*.sh' | xargs shellcheck",
    "format:sh": "git ls-files --cached --others --exclude-standard '*.sh' | xargs shfmt -i 2 -ci -bn -sr -d",
    "format:sh:fix": "git ls-files --cached --others --exclude-standard '*.sh' | xargs shfmt -i 2 -ci -bn -sr -w",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "postcss@<8.5.10": ">=8.5.10",
      "smol-toml@<1.6.1": ">=1.6.1",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "remeda": "^2.34.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "1.0.0",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^10.4.1",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-storybook": "^10.4.2",
    "eslint-plugin-unicorn": "^65.0.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "lefthook": "^2.1.8",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.3.5",
    "secretlint": "^13.0.2",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.7"
  },
  "knip": {
    "ignoreBinaries": [
      "actionlint",
      "gitleaks",
      "shellcheck",
      "shfmt"
    ],
    "ignoreDependencies": [
      "@commitlint/cli",
      "@commitlint/config-conventional",
      "@testing-library/jest-dom",
      "@testing-library/react",
      "postcss",
      "@secretlint/secretlint-rule-preset-recommend"
    ],
    "entry": [
      "src/shared-components/**/*.{ts,tsx}",
      "src/features/**/*.{ts,tsx}",
      "src/helpers/**/*.{ts,tsx}"
    ],
    "next": {
      "entry": [
        "src/app/**/{layout,page,loading,error,not-found,template,default}.{ts,tsx}",
        "next.config.ts"
      ]
    }
  }
}
